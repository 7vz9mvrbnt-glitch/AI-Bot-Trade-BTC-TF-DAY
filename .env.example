# ── LINE ────────────────────────────────────────────────────────────
LINE_CHANNEL_TOKEN=          # Channel access token (long-lived)
LINE_CHANNEL_SECRET=         # Channel secret

# กลุ่ม/ห้อง/user ที่ต้องการ push เวลา 07:00
# ใส่หลายค่าคั่นด้วย comma เช่น  Cxxxxxxxx,Uxxxxxxxx
LINE_PUSH_TARGETS=

# ── Google Sheets ────────────────────────────────────────────────────
SPREADSHEET_ID=              # ดูจาก URL ของ Sheet: /d/<ID>/edit
GOOGLE_CLIENT_EMAIL=         # service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=          # -----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----

# ── Vercel Cron ──────────────────────────────────────────────────────
CRON_SECRET=                 # สุ่มสตริงยาว ๆ ไว้ป้องกันคนอื่น call /api/cron

# ── Dashboard URL ────────────────────────────────────────────────────
# ใส่หลัง deploy แล้วได้ domain จาก Vercel
DASHBOARD_URL=https://your-project.vercel.app/dashboard.html
